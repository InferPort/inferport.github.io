---
import { Button } from "./ui/Button.tsx"
import { ArrowRight, Phone, Mail } from "lucide-react"

export interface Props {
  title: string
  text: string
  phone?: string
  email?: string
}

const {
  title,
  text,
  phone = "+57 323 612 3894",
  email = "info@inferport.co",
} = Astro.props
---

<section class="relative overflow-hidden bg-surface border-t border-border">
  <div
    class="absolute inset-0 bg-[linear-gradient(rgba(45,170,158,0.02)_1px,transparent_1px),linear-gradient(90deg,rgba(45,170,158,0.02)_1px,transparent_1px)] bg-[size:64px_64px]"
  />

  <div
    class="absolute top-1/2 left-1/3 w-96 h-96 rounded-full bg-brand-500/5 blur-[120px]"
  />

  <div class="container relative z-10 py-24 md:py-32">
    <div class="max-w-2xl mx-auto text-center">
      <h2
        class="text-3xl md:text-4xl lg:text-5xl font-semibold tracking-tight text-ink text-balance mb-6"
      >
        {title}
      </h2>

      <p
        class="text-lg text-ink-secondary max-w-[55ch] mx-auto text-balance leading-relaxed mb-10"
      >
        {text}
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href={`https://wa.me/${phone.replace(/\s/g, "")}`}
          target="_blank"
          rel="noopener noreferrer"
        >
          <Button variant="primary" size="lg">
            Escribir por WhatsApp
            <ArrowRight class="w-4 h-4" />
          </Button>
        </a>
      </div>

      <div
        class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-6 text-sm"
      >
        <a
          href={`tel:${phone.replace(/\s/g, "")}`}
          class="flex items-center gap-2 text-ink-secondary hover:text-brand-400 transition-colors"
        >
          <Phone class="w-4 h-4 text-brand-400" />
          {phone}
        </a>
        <a
          href={`mailto:${email}`}
          class="flex items-center gap-2 text-ink-secondary hover:text-brand-400 transition-colors"
        >
          <Mail class="w-4 h-4 text-brand-400" />
          {email}
        </a>
      </div>
    </div>
  </div>
</section>
