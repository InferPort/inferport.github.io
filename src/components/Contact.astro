---
import Section from "./Section.astro"
import { ContactForm } from "./ContactForm.tsx"
import { MapPin, Phone, Mail, Clock } from "lucide-react"
---

<Section>
  <Fragment slot="title">
    Contáctanos
  </Fragment>
  <Fragment slot="subtitle">
    Estamos ubicados en Cali, Colombia. Escríbenos o llámanos y te responderemos en breve.
  </Fragment>

  <div class="grid grid-cols-1 lg:grid-cols-5 gap-12">
    <div class="lg:col-span-3">
      <ContactForm client:load />
    </div>

    <div class="lg:col-span-2 space-y-8">
      <div class="animate-on-scroll" style="animation-delay: 0.15s">
        <h3 class="text-sm font-semibold text-ink mb-4">Información de contacto</h3>
        <div class="space-y-4">
          <a href="https://wa.me/573236123894" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 text-sm text-ink-secondary hover:text-brand-400 transition-colors">
            <Phone class="w-4 h-4 text-brand-400 shrink-0" />
            <span>+57 323 612 3894</span>
          </a>
          <a href="mailto:info@inferport.co" class="flex items-center gap-3 text-sm text-ink-secondary hover:text-brand-400 transition-colors">
            <Mail class="w-4 h-4 text-brand-400 shrink-0" />
            <span>info@inferport.co</span>
          </a>
          <div class="flex items-start gap-3 text-sm text-ink-secondary">
            <MapPin class="w-4 h-4 text-brand-400 mt-0.5 shrink-0" />
            <span>Cali, Valle del Cauca, Colombia</span>
          </div>
          <div class="flex items-start gap-3 text-sm text-ink-secondary">
            <Clock class="w-4 h-4 text-brand-400 mt-0.5 shrink-0" />
            <span>Lunes a viernes — 8:00 AM a 6:00 PM</span>
          </div>
        </div>
      </div>

      <div class="animate-on-scroll" style="animation-delay: 0.25s">
        <h3 class="text-sm font-semibold text-ink mb-4">Síguenos</h3>
        <div class="flex gap-3">
          <a
            href="https://facebook.com/inferport"
            target="_blank"
            rel="noopener noreferrer"
            class="w-10 h-10 rounded-lg bg-surface-elevated border border-border flex items-center justify-center text-ink-secondary hover:text-brand-400 hover:border-brand-500/30 transition-all duration-300"
            aria-label="Facebook"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
            </svg>
          </a>
          <a
            href="https://www.linkedin.com/company/inferport"
            target="_blank"
            rel="noopener noreferrer"
            class="w-10 h-10 rounded-lg bg-surface-elevated border border-border flex items-center justify-center text-ink-secondary hover:text-brand-400 hover:border-brand-500/30 transition-all duration-300"
            aria-label="LinkedIn"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</Section>
