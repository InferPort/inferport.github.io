---
import { Heart } from "lucide-react"
---

<footer class="border-t border-border">
  <div class="container py-12 md:py-16">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <div class="md:col-span-2">
        <img src="/images/logo-light.png" alt="InferPort" class="h-7 w-auto mb-4" />
        <p class="text-sm text-ink-secondary max-w-sm leading-relaxed">
          Expertos en desarrollo de software, soporte técnico e infraestructura tecnológica desde Cali, Colombia.
        </p>
      </div>

      <div>
        <h4 class="text-sm font-semibold text-ink mb-4">Servicios</h4>
        <ul class="space-y-2">
          <li><a href="/servicio-tecnico/" class="text-sm text-ink-secondary hover:text-brand-400 transition-colors">Servicio Técnico</a></li>
          <li><a href="/desarrollo/" class="text-sm text-ink-secondary hover:text-brand-400 transition-colors">Programación & Desarrollo</a></li>
          <li><a href="/asistencia-remota/" class="text-sm text-ink-secondary hover:text-brand-400 transition-colors">Asistencia Remota</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-sm font-semibold text-ink mb-4">Contacto</h4>
        <ul class="space-y-2">
          <li><a href="tel:+573236123894" class="text-sm text-ink-secondary hover:text-brand-400 transition-colors">+57 323 612 3894</a></li>
          <li><a href="mailto:info@inferport.co" class="text-sm text-ink-secondary hover:text-brand-400 transition-colors">info@inferport.co</a></li>
          <li><span class="text-sm text-ink-secondary">Cali, Colombia</span></li>
        </ul>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-border flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-ink-secondary">
        &copy; {new Date().getFullYear()} InferPort. Todos los derechos reservados.
      </p>
      <p class="text-xs text-ink-secondary flex items-center gap-1">
        Hecho con <Heart class="w-3 h-3 text-brand-400" /> en Cali
      </p>
    </div>
  </div>
</footer>
