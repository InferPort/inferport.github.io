---
import Section from "./Section.astro"
import { Search, FileText, Rocket, HeartHandshake } from "lucide-react"

const steps = [
  {
    icon: Search,
    title: "Diagnóstico",
    text: "Analizamos tu situación y entendemos tus necesidades tecnológicas a fondo.",
  },
  {
    icon: FileText,
    title: "Propuesta",
    text: "Te presentamos la solución con alcance, tiempos y presupuesto claro.",
  },
  {
    icon: Rocket,
    title: "Ejecución",
    text: "Implementamos la solución acordada con estándares profesionales de calidad.",
  },
  {
    icon: HeartHandshake,
    title: "Soporte continuo",
    text: "Acompañamiento post-servicio para garantizar resultados y resolver dudas.",
  },
]
---

<Section>
  <Fragment slot="title">
    Cómo <span class="text-brand-400">trabajamos</span>
  </Fragment>
  <Fragment slot="subtitle">
    Un proceso simple y transparente de principio a fin. Sin vueltas ni sorpresas.
  </Fragment>

  <div class="relative grid grid-cols-1 md:grid-cols-4 gap-8 md:gap-12">
    <div
      class="hidden md:block absolute top-12 left-[12.5%] right-[12.5%] h-px bg-border"
      aria-hidden="true"
    />

    {steps.map((step, i) => (
      <div
        class="relative flex flex-col items-center text-center animate-on-scroll stagger-scale"
        style={`animation-delay: ${i * 0.12}s`}
      >
        <div
          class="w-24 h-24 rounded-full bg-brand-500/5 flex items-center justify-center mb-6 relative z-10 border border-brand-500/20"
        >
          <step.icon class="w-9 h-9 text-brand-400" />
        </div>
        <span
          class="text-[11px] font-mono uppercase tracking-[0.2em] text-brand-400 mb-3"
        >
          Paso 0{i + 1}
        </span>
        <h3 class="text-lg font-semibold text-ink mb-2">{step.title}</h3>
        <p class="text-sm text-ink-secondary leading-relaxed max-w-xs">
          {step.text}
        </p>
      </div>
    ))}
  </div>
</Section>
