---
import { Button } from "./ui/Button.tsx"
import { ArrowRight, CheckCircle2 } from "lucide-react"

export interface Feature {
  icon: any
  text: string
}

export interface Props {
  badge: string
  title: string
  subtitle: string
  features: Feature[]
  ctaHref?: string
  ctaText?: string
  variant?: "terminal" | "none"
}

const { badge, title, subtitle, features, ctaHref = "https://wa.me/573236123894", ctaText = "Solicitar cotización", variant = "terminal" } = Astro.props
---

<section
  class="relative min-h-[85dvh] flex items-center overflow-hidden bg-surface"
>
  <div class="absolute inset-0 bg-[linear-gradient(rgba(45,170,158,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(45,170,158,0.03)_1px,transparent_1px)] bg-[size:64px_64px]" />

  <div class="absolute top-1/4 -left-32 w-96 h-96 rounded-full bg-brand-500/5 blur-[128px] animate-pulse" />
  <div class="absolute bottom-1/4 -right-32 w-80 h-80 rounded-full bg-brand-400/5 blur-[100px] animate-pulse" style="animation-delay: 2s" />

  <div class="absolute inset-0 gradient-mask" />

  <div class="container relative z-10 pt-28 pb-16 md:pt-36 md:pb-24">
    <div class={`grid grid-cols-1 gap-12 items-center ${variant === "none" ? "max-w-3xl" : "lg:grid-cols-2"}`}>
      <div class={variant === "none" ? "" : "max-w-xl"}>
        <div
          class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-brand-500/10 border border-brand-500/20 text-xs text-brand-400 font-mono mb-8"
        >
          <span class="w-1.5 h-1.5 rounded-full bg-brand-500 animate-pulse" />
          {badge}
        </div>

        <h1
          class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-semibold tracking-tight text-ink leading-[1.08] text-balance"
          set:html={title}
        />

        <p
          class="mt-6 text-lg md:text-xl text-ink-secondary max-w-[65ch] text-balance leading-relaxed"
        >
          {subtitle}
        </p>

        <div class="mt-8 grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-3">
          {features.map((feature) => (
            <div class="flex items-center gap-3 text-sm text-ink-secondary">
              <feature.icon class="w-4 h-4 text-brand-400 shrink-0" />
              <span>{feature.text}</span>
            </div>
          ))}
        </div>

        <div class="mt-10">
          <a href={ctaHref} target="_blank" rel="noopener noreferrer">
            <Button variant="primary" size="lg">
              {ctaText}
              <ArrowRight class="w-4 h-4" />
            </Button>
          </a>
        </div>
      </div>

      {variant === "terminal" && (
        <div class="hidden lg:flex justify-center">
          <div class="relative w-full max-w-md">
            <div
              class="rounded-2xl bg-surface-elevated border border-border overflow-hidden shadow-2xl"
            >
              <div class="flex items-center gap-1.5 px-4 py-3 border-b border-border">
                <span class="w-3 h-3 rounded-full bg-red-500/60" />
                <span class="w-3 h-3 rounded-full bg-yellow-500/60" />
                <span class="w-3 h-3 rounded-full bg-green-500/60" />
                <span class="ml-2 text-[11px] text-ink-secondary font-mono">terminal — inferport</span>
              </div>
              <div class="p-5 font-mono text-xs leading-relaxed space-y-1.5">
                <div class="animate-code-line" style="animation-delay: 0s">
                  <span class="text-green-400">user@inferport</span><span class="text-ink-secondary">:</span><span class="text-brand-400">~</span><span class="text-ink-secondary">$ </span>
                  <span class="text-ink">contactar --servicio --rapido</span>
                </div>
                <div class="animate-code-line text-ink-secondary" style="animation-delay: 0.5s">
                  &nbsp;&nbsp;✓ Conectando con el equipo de InferPort...
                </div>
                <div class="animate-code-line text-ink-secondary" style="animation-delay: 1s">
                  &nbsp;&nbsp;✓ Revisando disponibilidad...
                </div>
                <div class="animate-code-line text-ink-secondary" style="animation-delay: 1.5s">
                  &nbsp;&nbsp;✓ Presupuesto generado en 2.3s
                </div>
                <div class="animate-code-line" style="animation-delay: 2s">
                  <span class="text-green-400">user@inferport</span><span class="text-ink-secondary">:</span><span class="text-brand-400">~</span><span class="text-ink-secondary">$ </span>
                  <span class="text-brand-400 animate-pulse">▊</span>
                </div>
                <div class="animate-code-line text-ink-secondary text-center pt-3 border-t border-border mt-3" style="animation-delay: 2.5s">
                  ¿Hablamos? Escríbenos ahora y te respondemos en minutos.
                </div>
              </div>
            </div>

            <div
              class="absolute -bottom-4 -right-4 w-64 h-32 bg-brand-500/5 blur-[60px] rounded-full"
              aria-hidden="true"
            />
          </div>
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .animate-code-line {
    opacity: 0;
    animation: code-fade-in 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes code-fade-in {
    from {
      opacity: 0;
      transform: translateY(4px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
