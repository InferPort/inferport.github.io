---
import { Button } from "./ui/Button.tsx"
import { ArrowRight, Code, Server, HeadphonesIcon } from "lucide-react"
---

<section id="inicio" class="relative min-h-[100dvh] flex items-center overflow-hidden bg-surface">
  <div class="absolute inset-0 bg-[linear-gradient(rgba(45,170,158,0.03)_1px,transparent_1px),linear-gradient(90deg,rgba(45,170,158,0.03)_1px,transparent_1px)] bg-[size:64px_64px]" />

  <div class="absolute top-1/4 -left-32 w-96 h-96 rounded-full bg-brand-500/5 blur-[128px] animate-pulse" />
  <div class="absolute bottom-1/4 -right-32 w-80 h-80 rounded-full bg-brand-400/5 blur-[100px] animate-pulse" style="animation-delay: 2s" />

  <div class="absolute inset-0 gradient-mask" />

  <div class="container relative z-10 pt-24 pb-16 md:pt-32 md:pb-24">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <div class="max-w-xl">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-brand-500/10 border border-brand-500/20 text-xs text-brand-400 font-mono mb-8">
          <span class="w-1.5 h-1.5 rounded-full bg-brand-500 animate-pulse" />
          Servicios tecnológicos profesionales
        </div>

        <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-semibold tracking-tight text-ink leading-[1.05] text-balance">
          Desarrollo y soporte<br />
          <span class="text-brand-400">técnico profesional</span>
        </h1>

        <p class="mt-6 text-lg md:text-xl text-ink-secondary max-w-[65ch] text-balance leading-relaxed">
          Expertos en software, infraestructura y soporte técnico para impulsar tu negocio.
        </p>

        <div class="mt-10 flex flex-col sm:flex-row gap-4">
          <a href="https://wa.me/573236123894" target="_blank" rel="noopener noreferrer">
            <Button variant="primary" size="lg">
              Solicitar cotización
              <ArrowRight class="w-4 h-4" />
            </Button>
          </a>
          <a href="/#servicios">
            <Button variant="secondary" size="lg">
              Ver servicios
            </Button>
          </a>
        </div>

        <div class="mt-12 grid grid-cols-1 sm:grid-cols-3 gap-4">
          <div class="flex items-center gap-3 text-sm text-ink-secondary">
            <Code class="w-4 h-4 text-brand-400 shrink-0" />
            <span>Desarrollo de software</span>
          </div>
          <div class="flex items-center gap-3 text-sm text-ink-secondary">
            <Server class="w-4 h-4 text-brand-400 shrink-0" />
            <span>Infraestructura TI</span>
          </div>
          <div class="flex items-center gap-3 text-sm text-ink-secondary">
            <HeadphonesIcon class="w-4 h-4 text-brand-400 shrink-0" />
            <span>Soporte 24/7</span>
          </div>
        </div>
      </div>

      <div class="hidden lg:flex justify-center">
        <div class="relative w-full max-w-md">
          <div class="rounded-2xl bg-surface-elevated border border-border overflow-hidden shadow-2xl">
            <div class="flex items-center gap-1.5 px-4 py-3 border-b border-border">
              <span class="w-3 h-3 rounded-full bg-red-500/60" />
              <span class="w-3 h-3 rounded-full bg-yellow-500/60" />
              <span class="w-3 h-3 rounded-full bg-green-500/60" />
              <span class="ml-2 text-[11px] text-ink-secondary font-mono">terminal — inferport</span>
            </div>
            <div class="p-5 font-mono text-xs leading-relaxed">
              <div class="animate-code-line" style="animation-delay: 0s">
                <span class="text-green-400">user@inferport</span><span class="text-ink-secondary">:</span><span class="text-brand-400">~</span><span class="text-ink-secondary">$ </span>
                <span class="text-ink">npm run deploy -- --production</span>
              </div>
              <div class="animate-code-line text-ink-secondary" style="animation-delay: 0.5s">
                &nbsp;&nbsp;✓ Building project...
              </div>
              <div class="animate-code-line text-ink-secondary" style="animation-delay: 1s">
                &nbsp;&nbsp;✓ 35 modules transformed
              </div>
              <div class="animate-code-line text-ink-secondary" style="animation-delay: 1.5s">
                &nbsp;&nbsp;✓ 1 page(s) built in 2.15s
              </div>
              <div class="animate-code-line" style="animation-delay: 2s">
                <span class="text-green-400">user@inferport</span><span class="text-ink-secondary">:</span><span class="text-brand-400">~</span><span class="text-ink-secondary">$ </span>
                <span class="text-brand-400 animate-pulse">▊</span>
              </div>
            </div>
          </div>

          <div class="absolute -bottom-4 -right-4 w-64 h-32 bg-brand-500/5 blur-[60px] rounded-full" aria-hidden="true" />
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .animate-code-line {
    opacity: 0;
    animation: code-fade-in 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes code-fade-in {
    from {
      opacity: 0;
      transform: translateY(4px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
